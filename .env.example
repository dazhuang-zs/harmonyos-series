# LLM Provider: mimo / deepseek / openai
LLM_PROVIDER=mimo

# MiMo API
MIMO_API_KEY=your_mimo_api_key
MIMO_BASE_URL=https://api.mimo.com/v1

# DeepSeek API (备用)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI Compatible API (备用)
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# Embedding Model
EMBEDDING_MODEL_PATH=BAAI/bge-large-zh-v1.5

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=harmonyos_docs

# CSDN
CSDN_COOKIE=your_csdn_cookie

# App
APP_ENV=development
APP_DEBUG=true
